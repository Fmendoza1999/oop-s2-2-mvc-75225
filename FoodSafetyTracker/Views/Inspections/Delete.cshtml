@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "Delete Inspection";
}

<h2>Delete Inspection</h2>
<div class="alert alert-danger">
    Are you sure you want to delete this inspection for <strong>@Model.Premises.Name</strong>?
</div>

<dl class="row">
    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.InspectionDate.ToShortDateString()</dd>
    <dt class="col-sm-3">Score</dt>
    <dd class="col-sm-9">@Model.Score</dd>
    <dt class="col-sm-3">Outcome</dt>
    <dd class="col-sm-9">@Model.Outcome</dd>
</dl>

<form asp-action="Delete">
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>