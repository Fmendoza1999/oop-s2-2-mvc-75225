@model FoodSafetyTracker.Models.Inspection
@{
    ViewData["Title"] = "Add Inspection";
}

<h2>Add Inspection</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="PremisesId" class="form-label">Premises</label>
                <select asp-for="PremisesId" asp-items="ViewBag.PremisesId" class="form-select">
                    <option value="">-- Select Premises --</option>
                </select>
                <span asp-validation-for="PremisesId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="InspectionDate" class="form-label"></label>
                <input asp-for="InspectionDate" type="date" class="form-control" />
                <span asp-validation-for="InspectionDate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Score" class="form-label">Score (0-100)</label>
                <input asp-for="Score" type="number" min="0" max="100" class="form-control" />
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Outcome" class="form-label"></label>
                <select asp-for="Outcome" class="form-select">
                    <option value="Pass">Pass</option>
                    <option value="Fail">Fail</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>