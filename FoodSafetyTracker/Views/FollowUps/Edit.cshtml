@model FoodSafetyTracker.Models.FollowUp
@{
    ViewData["Title"] = "Edit Follow-Up";
}

<h2>Edit Follow-Up</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="InspectionId" class="form-label">Inspection</label>
                <select asp-for="InspectionId" asp-items="ViewBag.InspectionId" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="DueDate" class="form-label"></label>
                <input asp-for="DueDate" type="date" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select">
                    <option value="Open">Open</option>
                    <option value="Closed">Closed</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="ClosedDate" class="form-label">Closed Date (required if Closed)</label>
                <input asp-for="ClosedDate" type="date" class="form-control" />
                <span asp-validation-for="ClosedDate" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>