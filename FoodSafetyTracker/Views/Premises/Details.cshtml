@model FoodSafetyTracker.Models.Premises
@{
    ViewData["Title"] = "Premises Details";
}

<h2>@Model.Name</h2>
<hr />

<dl class="row">
    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@Model.Address</dd>
    <dt class="col-sm-3">Town</dt>
    <dd class="col-sm-9">@Model.Town</dd>
    <dt class="col-sm-3">Risk Rating</dt>
    <dd class="col-sm-9">
        <span class="badge @(Model.RiskRating == "High" ? "bg-danger" : Model.RiskRating == "Medium" ? "bg-warning text-dark" : "bg-success")">
            @Model.RiskRating
        </span>
    </dd>
</dl>

<h4>Inspections</h4>
<table class="table table-sm">
    <thead>
        <tr><th>Date</th><th>Score</th><th>Outcome</th></tr>
    </thead>
    <tbody>
        @foreach (var i in Model.Inspections)
        {
            <tr>
                <td>@i.InspectionDate.ToShortDateString()</td>
                <td>@i.Score</td>
                <td><span class="badge @(i.Outcome == "Fail" ? "bg-danger" : "bg-success")">@i.Outcome</span></td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Back</a>